Year = 2022,
# V7 is the standard column for 'Total Housing Units' authorized
Permit_Units = V7,
# V8 is the total 'Valuation' (dollar amount) of those permits
Permit_Valuation = V8
) %>%
select(FIPS, Year, Permit_Units, Permit_Valuation, County_Name = V6)
