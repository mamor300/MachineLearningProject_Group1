group_by(fips, Year) %>%
summarise(across(matches("Studio|OneRoom|TwoRoom|ThreeRoom|FourRoom"), mean, na.rm = TRUE),
across(c(state_alpha), first),
.groups = "drop") %>%
rename_with(~ paste0(., "_fmr"), matches("Studio|OneRoom|TwoRoom|ThreeRoom|FourRoom")) %>%
