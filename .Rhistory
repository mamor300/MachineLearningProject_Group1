## Previous CFPB data frame and references to it are changed to CFPB3
CFPB <- CFPB3 |>
left_join(INSECURE |>
select(-`County Name`,-State),
by = c("FIPS","Year"))|>
left_join(DebtMetrics |>
select(-`County Name`,-`State Name`),
by ="FIPS") |>
select(-ZIP.missing)
